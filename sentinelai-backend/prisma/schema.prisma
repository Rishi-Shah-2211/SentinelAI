generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  action    String
  device    String?
  location  String?
  riskScore Float
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([timestamp])
}

model UserRisk {
  id        String   @id @default(cuid())
  userId    String
  riskScore Float
  createdAt DateTime @default(now())

  @@index([userId])
}

model Alert {
  id        String   @id @default(cuid())
  userId    String
  riskScore Float
  message   String
  createdAt DateTime @default(now())

  @@index([userId])
}